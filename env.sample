# Copy this file to .env and fill in the values

# Local Docker (make mongo)
# MONGO_URI=mongodb://localhost:27017
# Atlas
# MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net

# Inside fullstack-webapp-starter (docker compose) — use the service name
# MONGO_URI=mongodb://<user>:<password>@mongo:27017/<db>?authSource=admin
MONGO_URI=

MONGO_DB=mydatabase
BACKEND_NAME=myappname
BACKEND_VERSION=0.0.1
